{
  "name": "Python DevContainer",
  "image": "medsnok7/gen_ai:latest",
  "workspaceFolder": "/workspaces/generative_model",
  "runArgs": [
    "--dns=8.8.8.8",
    "--dns=8.8.4.4"
  ],
  "settings": {
    "python.defaultInterpreterPath": "/usr/local/bin/python"
  },
  "extensions": [
    "ms-python.python",
    "ms-python.vscode-pylance"
  ],
  "forwardPorts": [8000],
  "postCreateCommand": "pip install --upgrade pip --root-user-action=ignore --disable-pip-version-check --quiet"
}